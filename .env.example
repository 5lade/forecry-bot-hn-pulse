# forecry-bot-hn-pulse — example environment configuration.
# Copy to .env and fill in real values for local development.
# Every key listed here is required at startup (see src/config.ts).

# Postgres connection string (e.g. postgres://user:pass@host:5432/db).
DATABASE_URL=

# Telegram bot token from @BotFather (format: <id>:<hash>).
TG_BOT_TOKEN=

# Stripe API secret key (sk_test_... in dev, sk_live_... in prod).
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...) for /stripe/webhook.
STRIPE_WEBHOOK_SECRET=

# Public origin where this service is reachable (used for Stripe redirects, etc.).
PUBLIC_URL=

# Runtime environment: development | test | production.
NODE_ENV=development

# Pino log level: fatal | error | warn | info | debug | trace.
LOG_LEVEL=info
